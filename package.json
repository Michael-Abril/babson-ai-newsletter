{
  "name": "the-ai-pulse",
  "version": "1.0.0",
  "description": "The AI Pulse — Babson College's automated weekly AI newsletter for entrepreneurs",
  "type": "module",
  "scripts": {
    "preview": "cross-env MODE=preview tsx src/index.ts",
    "test-send": "cross-env MODE=test tsx src/index.ts",
    "send": "cross-env MODE=send tsx src/index.ts",
    "multi-agent:preview": "cross-env MODE=preview tsx src/multi-agent.ts",
    "multi-agent:test": "cross-env MODE=test tsx src/multi-agent.ts",
    "multi-agent:send": "cross-env MODE=send tsx src/multi-agent.ts",
    "validate:links": "tsx src/validate-links.ts",
    "audit": "tsx src/agents/audit-orchestrator.ts",
    "build": "tsc --noEmit",
    "preflight": "npm run validate:links && npm run build"
  },
  "keywords": [
    "ai",
    "newsletter",
    "babson",
    "entrepreneurship"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "dotenv": "^17.3.1",
    "resend": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "cross-env": "^10.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
